{
    "name": "Selcom Payment Gateway",
    "slug": "selcom-payment",
    "version": "1.0.0",
    "description": "Accept payments via M-Pesa, Tigo Pesa, Airtel Money through Selcom",
    "author": "JamVini",
    "type": "payment_gateway",
    "core": false,
    "premium": true,
    "price": "TZS 50,000",
