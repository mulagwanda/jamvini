            "route": "admin.selcom.index",
            "position": 60,
            "section": "main"
        }
    },
    "hooks_provides": ["payment.received", "payment.failed"],
    "hooks_listens": ["invoice.paid"],
    "settings_page": "admin.selcom.settings",
    "permissions": ["manage_selcom_payment"]
